    {
      "parameters": {
        "jsCode": "// Берем все поля из строки и объединяем в один текст\nconst row = $json;\nconst keys = Object.keys(row);\n\n// Пропускаем пустые строки (если все поля пустые)\nconst values = keys.map(k => row[k]).filter(v => v && String(v).trim());\nif (values.length === 0) {\n  return []; // пропускаем\n}\n\n// Первый непустой ключ - это ID\nconst firstKey = keys[0];\nconst id = String(row[firstKey] || 'row_' + $itemIndex).replace(/[^a-zA-Z0-9_]/g, '_').toLowerCase();\n\n// Второй ключ - это заголовок\nconst title = row[keys[1]] || row[keys[0]] || 'Без названия';\n\n// Объединяем все поля в текст\nconst text = keys.map(k => `${k}: ${row[k] || ''}`).join('. ');\n\nreturn [{\n  json: {\n    id: id + '_' + $itemIndex,\n    title: title,\n    text: text\n  }\n}];"
      },
