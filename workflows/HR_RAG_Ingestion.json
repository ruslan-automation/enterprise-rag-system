        "jsCode": "const embedding = $json.embeddings[0];\nconst id = $('Combine All Fields').item.json.id;\nconst title = $('Combine All Fields').item.json.title;\nconst text = $('Combine All Fields').item.json.text;\n\nreturn [{\n  json: {\n    vectors: [{\n      id: id,\n      values: embedding,\n      metadata: {\n        title: title,\n        text: text\n      }\n    }]\n  }\n}];"
