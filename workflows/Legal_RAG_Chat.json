      "parameters": {
        "jsCode": "const matches = $json.matches || [];\n\n// Ищем question из разных источников (текст или голос)\nlet question;\nlet chatId;\n\ntry {\n  question = $('Extract Question').item.json.question;\n  chatId = $('Extract Question').item.json.chat_id;\n} catch (e) {\n  try {\n    question = $('Format Voice Input').item.json.question;\n    chatId = $('Format Voice Input').item.json.chat_id;\n  } catch (e2) {\n    question = 'Вопрос не найден';\n    chatId = null;\n  }\n}\n\nconst context = matches.map((match, index) => {\n  const title = match.metadata?.title || 'Без названия';\n  const text = match.metadata?.text || '';\n  return `[${index + 1}] ${title}:\\n${text}`;\n}).join('\\n\\n---\\n\\n');\n\nreturn [{\n  json: {\n    question: question,\n    chat_id: chatId,\n    context: context || 'Контекст не найден'\n  }\n}];"
      },
